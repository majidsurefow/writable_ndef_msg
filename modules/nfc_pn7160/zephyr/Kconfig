# NXP PN7160 NFC controller — out-of-tree Zephyr module

DT_COMPAT_NXP_PN7160 := nxp,pn7160

menuconfig PN7160
	bool "NXP PN7160 NFC controller"
	default y
	depends on DT_HAS_NXP_PN7160_ENABLED
	select I2C if $(dt_compat_on_bus,$(DT_COMPAT_NXP_PN7160),i2c)
	select SPI if $(dt_compat_on_bus,$(DT_COMPAT_NXP_PN7160),spi)
	help
	  Enable the PN7160 NFC controller driver, TML framing, and NCI stack.
	  Transport (I2C or SPI) is selected by devicetree — one bus per instance.

if PN7160

config PN7160_TML_I2C
	def_bool $(dt_compat_on_bus,$(DT_COMPAT_NXP_PN7160),i2c)
	help
	  Compile I2C TML backend when any enabled PN7160 instance is on I2C.

config PN7160_TML_SPI
	def_bool $(dt_compat_on_bus,$(DT_COMPAT_NXP_PN7160),spi)
	help
	  Compile SPI TML backend when any enabled PN7160 instance is on SPI.

config PN7160_INIT_PRIORITY
	int "PN7160 driver init priority"
	default 80
	help
	  Device driver initialization priority. Must run after I2C/SPI controller init.

config PN7160_RX_BUF_SIZE
	int "PN7160 RX buffer size"
	default 258
	help
	  Static RX buffer for NCI responses.

config PN7160_WORKQ_STACK_SIZE
	int "PN7160 module work queue stack size"
	default 1024
	help
	  Stack for the module-local work queue that drains HOST_IRQ events.
	  Replaced by nfc_work_q when HAL integration lands (Phase 0.6).

config PN7160_WORKQ_PRIORITY
	int "PN7160 module work queue priority"
	default 5
	help
	  Priority of the module-local PN7160 work queue thread.

config PN7160_SHELL
	bool "PN7160 shell commands"
	default y
	depends on SHELL
	help
	  Register pn7160 shell commands: probe, fwver, init, settings, discovery,
	  reset, xcv (raw NCI transceive), and dwl enter/leave/status.

module = PN7160
module-str = pn7160
source "subsys/logging/Kconfig.template.log_config"

endif # PN7160
