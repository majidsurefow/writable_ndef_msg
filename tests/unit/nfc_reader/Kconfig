mainmenu "NFC reader applet unit tests"

source "Kconfig.zephyr"

config NFC_PROTOCOL_NDEF
	bool "NDEF Type-4 protocol model"
	default n

config NFC_PROTOCOL_ULTRALIGHT
	bool "MIFARE Ultralight / NTAG protocol model"
	default n
	select NFC_PROTOCOL_NDEF

config NFC_PROTOCOL_CLASSIC
	bool "MIFARE Classic protocol model (clone-only)"
	default n

config NFC_PROTOCOL_FELICA
	bool "FeliCa protocol model (clone-only)"
	default n

config NFC_PROTOCOL_ISO15693_3
	bool "ISO15693-3 protocol model (clone-only parent)"
	default n

config NFC_PROTOCOL_SLIX
	bool "NXP SLIX protocol model (clone-only)"
	default n
	select NFC_PROTOCOL_ISO15693_3

config NFC_PROTOCOL_DESFIRE
	bool "MIFARE DESFire protocol model (partial emulatable)"
	default n

config NFC_PROTOCOL_EMV
	bool "EMV contactless protocol model (partial emulatable)"
	default n

config NFC_PROTOCOL_ALIRO
	bool "Aliro credential protocol model (partial emulatable)"
	default n

config NFC_EMV_MAX_RECORDS
	int "Maximum EMV READ RECORD blobs"
	default 2
	range 1 4
	depends on NFC_PROTOCOL_EMV

config NFC_EMV_RECORD_SIZE
	int "Maximum EMV tag-70 record size"
	default 64
	range 32 128
	depends on NFC_PROTOCOL_EMV

config NFC_ALIRO_MAX_TRANSCRIPT
	int "Maximum Aliro AUTH transcript bytes"
	default 512
	range 128 1024
	depends on NFC_PROTOCOL_ALIRO

config NFC_DESFIRE_MAX_APPS
	int "Maximum DESFire applications"
	default 1
	range 1 4
	depends on NFC_PROTOCOL_DESFIRE

config NFC_DESFIRE_MAX_FILES_PER_APP
	int "Maximum DESFire files per application"
	default 2
	range 1 8
	depends on NFC_PROTOCOL_DESFIRE

config NFC_DESFIRE_MAX_FILE_SIZE
	int "Maximum DESFire file payload"
	default 64
	range 16 256
	depends on NFC_PROTOCOL_DESFIRE

config FELICA_BLOCKS_MAX
	int "Maximum FeliCa blocks in data model"
	default 64
	range 16 64
	depends on NFC_PROTOCOL_FELICA

config ISO15693_BLOCKS_MAX
	int "Maximum ISO15693 blocks in data model"
	default 256
	range 16 256
	depends on NFC_PROTOCOL_ISO15693_3

config ISO15693_BLOCK_SIZE_MAX
	int "Maximum ISO15693 block size (bytes)"
	default 32
	range 4 32
	depends on NFC_PROTOCOL_ISO15693_3

config NFC_CLASSIC_BLOCK_COUNT
	int "Maximum Classic blocks in data model"
	default 256
	range 64 256
	depends on NFC_PROTOCOL_CLASSIC

config NFC_CLASSIC_TEST_DETERMINISTIC_NR
	bool "Use fixed NR bytes in Classic poller unit tests"
	default n
	depends on NFC_PROTOCOL_CLASSIC

config NFC_READER_CLASSIC_4K_ONLY
	bool "Build only Classic 4K reader aggregate tests (QEMU RAM isolation)"
	default n
	depends on NFC_PROTOCOL_CLASSIC

config NFC_VIRTUAL_LOOPBACK_MAX_BLOB
	int "Virtual loopback staging blob size (bytes)"
	default 2048
	range 2048 8192

config NFC_ULTRALIGHT_MAX_PAGES
	int "Maximum Ultralight pages in data model"
	default 256
	range 16 256
	depends on NFC_PROTOCOL_ULTRALIGHT

config NFC_NDEF_MAX_SIZE
	int "Maximum NDEF message payload (bytes)"
	default 500
	range 1 4096

config NFC_STORE
	bool "Enable store envelope tests"
	default y

config NFC_STORE_BLOB_SIZE
	int "Staging buffer size for serialized blobs (bytes)"
	default 4096
	depends on NFC_STORE
	range 512 16384

config NFC_STORE_MAX_TAG_LEN
	int "Maximum tag name length including NUL"
	default 16
	depends on NFC_STORE
	range 8 32

# Stub for src/nfc/nfc_config.h + emulate policy (mirrors CONFIG_NFC_ROLE_LISTEN).
config NFC_ROLE_LISTEN
	bool "Listen role (enables emulate policy compile path)"
	default y

# L1 applet headless service (P5: shell_off scenario)
# Default n to save RAM for constrained scenarios like store_ram.
# Enable explicitly in scenarios that need headless applet tests.
config NFC_APPLETS
	bool "NFC applet service (headless L1)"
	default n

config NFC_STORE_RAM
	bool "In-RAM multi-slot store backend"
	default n
	depends on NFC_STORE

if NFC_STORE_RAM

config NFC_STORE_RAM_SLOT_COUNT
	int "Number of RAM store slots"
	default 4
	depends on NFC_STORE_RAM
	range 1 16

config NFC_STORE_GOLDENS
	bool "Compiled-in store goldens for import tests"
	default n
	depends on NFC_STORE_RAM

endif
