mainmenu "NFC reader applet unit tests"

source "Kconfig.zephyr"

config NFC_PROTOCOL_NDEF
	bool "NDEF Type-4 protocol model"
	default n

config NFC_PROTOCOL_ULTRALIGHT
	bool "MIFARE Ultralight / NTAG protocol model"
	default n
	select NFC_PROTOCOL_NDEF

config NFC_PROTOCOL_CLASSIC
	bool "MIFARE Classic protocol model (clone-only)"
	default n

config NFC_PROTOCOL_FELICA
	bool "FeliCa protocol model (clone-only)"
	default n

config NFC_PROTOCOL_ISO15693_3
	bool "ISO15693-3 protocol model (clone-only parent)"
	default n

config NFC_PROTOCOL_SLIX
	bool "NXP SLIX protocol model (clone-only)"
	default n
	select NFC_PROTOCOL_ISO15693_3

config NFC_PROTOCOL_DESFIRE
	bool "MIFARE DESFire protocol model (partial emulatable)"
	default n

config NFC_DESFIRE_MAX_APPS
	int "Maximum DESFire applications"
	default 1
	range 1 4
	depends on NFC_PROTOCOL_DESFIRE

config NFC_DESFIRE_MAX_FILES_PER_APP
	int "Maximum DESFire files per application"
	default 2
	range 1 8
	depends on NFC_PROTOCOL_DESFIRE

config NFC_DESFIRE_MAX_FILE_SIZE
	int "Maximum DESFire file payload"
	default 64
	range 16 256
	depends on NFC_PROTOCOL_DESFIRE

config FELICA_BLOCKS_MAX
	int "Maximum FeliCa blocks in data model"
	default 64
	range 16 64
	depends on NFC_PROTOCOL_FELICA

config ISO15693_BLOCKS_MAX
	int "Maximum ISO15693 blocks in data model"
	default 256
	range 16 256
	depends on NFC_PROTOCOL_ISO15693_3

config ISO15693_BLOCK_SIZE_MAX
	int "Maximum ISO15693 block size (bytes)"
	default 32
	range 4 32
	depends on NFC_PROTOCOL_ISO15693_3

config NFC_CLASSIC_BLOCK_COUNT
	int "Maximum Classic blocks in data model"
	default 256
	range 64 256
	depends on NFC_PROTOCOL_CLASSIC

config NFC_ULTRALIGHT_MAX_PAGES
	int "Maximum Ultralight pages in data model"
	default 256
	range 16 256
	depends on NFC_PROTOCOL_ULTRALIGHT

config NFC_NDEF_MAX_SIZE
	int "Maximum NDEF message payload (bytes)"
	default 500
	range 1 4096

config NFC_STORE
	bool "Enable store envelope tests"
	default y

config NFC_STORE_BLOB_SIZE
	int "Staging buffer size for serialized blobs (bytes)"
	default 4096
	depends on NFC_STORE
	range 512 16384

config NFC_STORE_MAX_TAG_LEN
	int "Maximum tag name length including NUL"
	default 16
	depends on NFC_STORE
	range 8 32
