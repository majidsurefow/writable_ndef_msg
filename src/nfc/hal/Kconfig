# NFC HAL backend selection.

choice NFC_HAL_BACKEND
	prompt "NFC HAL backend"
	default NFC_HAL_BACKEND_PN7160
	depends on NFC_STACK

config NFC_HAL_BACKEND_PN7160
	bool "PN7160 NCI (SMART tier)"
	depends on PN7160
	help
	  Use the out-of-tree PN7160 Zephyr driver and NCI API.

endchoice

config NFC_ROLE_READER
	bool "Reader role"
	default y
	depends on NFC_STACK
	help
	  Enable reader-mode discovery and tag transceive APIs.

config NFC_ROLE_LISTEN
	bool "Listen (card emulation) role"
	default y
	depends on NFC_STACK
	help
	  Enable listen sub-API (start/stop/send_response). Gate 1 skeleton on PN7160.

config NFC_HAL_SHELL
	bool "NFC transport HAL shell commands"
	default y
	depends on NFC_STACK && SHELL
	help
	  Register nfc_transport config|stats|state shell subcommands.
