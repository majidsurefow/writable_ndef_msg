config NFC_READER
	bool "NFC reader engine"
	default n
	depends on NFC_STACK && NFC_ROLE_READER
	select NFC_PROTOCOL_NDEF if NFC_STORE
	help
	  Reader discovery engine, NDEF clone, and shell commands.

if NFC_READER

config NFC_READER_SHELL
	bool "NFC reader shell commands"
	default y
	depends on SHELL
	help
	  Register nfc reader scan and clone shell commands.

config NFC_READER_SCAN_TIMEOUT_MS
	int "Default reader scan timeout (milliseconds)"
	default 10000
	range 1000 60000
	help
	  Maximum time to wait for a tag during nfc reader scan.

endif
