# NFC card store — Gate 2 minimal envelope.

config NFC_STORE
	bool "NFC card store (minimal envelope)"
	default n
	depends on NFC_STACK
	help
	  Versioned TLV + CRC .card blob save/load. Gate 2 subset without NVS.

if NFC_STORE

config NFC_STORE_BLOB_SIZE
	int "Staging buffer size for serialized blobs (bytes)"
	default 4096
	range 512 16384

config NFC_STORE_MAX_TAG_LEN
	int "Maximum tag name length including NUL"
	default 16
	range 8 32

config NFC_STORE_RAM
	bool "In-RAM multi-slot store backend"
	default n
	help
	  Register save/load callbacks backed by a fixed RAM slot table.
	  Enables nfc read → nfc emulate without hex import.

if NFC_STORE_RAM

config NFC_STORE_RAM_SLOT_COUNT
	int "Number of RAM store slots"
	default 4
	range 1 16

config NFC_STORE_RAM_SHELL
	bool "RAM store shell commands (list, dump)"
	default y
	depends on SHELL

endif

endif
