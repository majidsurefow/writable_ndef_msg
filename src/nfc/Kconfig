# NFC stack — HAL + orchestrators (backend-neutral).

config NFC_STACK
	bool "NFC stack"
	help
	  NFC transport HAL and stack scaffolding. Select a HAL backend
	  (PN7160 reader+listen or NFCT listen-only) in hal/Kconfig.

if NFC_STACK

config NFC_APDU_BUF_SIZE
	int "Inbound APDU net_buf data size (bytes)"
	default 512
	range 64 512
	help
	  Data bytes per FIXED net_buf in the HAL listen path.

config NFC_APDU_POOL_COUNT
	int "Inbound APDU net_buf pool count"
	default 4
	range 1 16
	help
	  Number of FIXED net_bufs for ISR-to-WQ APDU assembly.

