# FeliCa protocol — cookbook §5.7 (F4, clone-only).

config NFC_PROTOCOL_FELICA
	bool "FeliCa protocol model"
	default n
	depends on NFC_STACK
	help
	  FeliCa Lite block dump model, poller, and virtual listener for tests.
	  Product RF emulate remains clone-only (ENOTSUP).

if NFC_PROTOCOL_FELICA

config FELICA_BLOCKS_MAX
	int "Maximum FeliCa blocks in data model"
	default 64
	range 16 64

endif
