# MIFARE Classic protocol — cookbook §5.3 (F2, clone-only).

config NFC_PROTOCOL_CLASSIC
	bool "MIFARE Classic protocol model"
	default n
	depends on NFC_STACK
	help
	  Classic block data model, TAG-CMD poller, and virtual listener
	  for QEMU loopback. NFCT product emulate remains clone-only.

if NFC_PROTOCOL_CLASSIC

config NFC_CLASSIC_BLOCK_COUNT
	int "Maximum Classic blocks in data model"
	default 256
	range 64 256
	help
	  Largest supported tag (Classic 4K = 256 blocks).

config NFC_CLASSIC_TEST_DETERMINISTIC_NR
	bool "Use fixed NR bytes in poller unit tests"
	default n
	help
	  Deterministic Crypto1 auth for Tier B session-mock fixtures.

endif
